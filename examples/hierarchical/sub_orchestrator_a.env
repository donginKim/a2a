# Sub-Orchestrator A (팀 A)
# 자체 에이전트들과 토론 후, 결과를 Meta-Orchestrator에 반환합니다.
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
ORCHESTRATOR_NAME=Team-A-Orchestrator
DEBATE_ROUNDS=2
OUTPUT_DIR=./reports/team-a
AGENTS_FILE=./agents_team_a.json

# 계층형: Meta-Orchestrator에 등록
PARENT_ORCHESTRATOR_URL=http://localhost:9000
ORCHESTRATOR_PUBLIC_URL=http://localhost:8000
ORCHESTRATOR_SKILLS=backend,api-design,database
