# 오케스트레이터 서버 설정
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000

# 오케스트레이터 정보
ORCHESTRATOR_NAME=A2A Orchestrator
DEBATE_ROUNDS=2
OUTPUT_DIR=./reports

# 에이전트 목록 파일 경로
AGENTS_FILE=./agents.json

# --- 계층형 오케스트레이터 설정 (선택사항) ---
# 상위 오케스트레이터 URL (설정하면 하위 오케스트레이터로 동작)
# PARENT_ORCHESTRATOR_URL=http://<META_ORCHESTRATOR_IP>:9000

# 이 오케스트레이터의 공개 URL (상위에서 접근 가능한 URL)
# ORCHESTRATOR_PUBLIC_URL=http://<THIS_IP>:8000

# 상위에 광고할 스킬 (쉼표 구분)
# ORCHESTRATOR_SKILLS=backend-analysis,infra-debate

# 하위 오케스트레이터 호출 시 타임아웃 (초, 기본 600)
# SUB_ORCHESTRATOR_TIMEOUT=600

# 대시보드 표시용 별칭 (없으면 ORCHESTRATOR_NAME 사용)
# ORCHESTRATOR_ALIAS=메타
